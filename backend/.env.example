# Local Environment Configuration Template
# Copy this file to '.env' and fill in your local system parameters.
# NEVER commit the actual '.env' file containing secret keys to GitHub.

# Server Configuration
PORT=5000
FLASK_DEBUG=True
SECRET_KEY=enter_your_secret_session_key_here

# Database Configuration (MySQL)
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=paper_plane_db

# External AI Service Credentials
# Generate your API Key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Credentials
OPENAI_API_KEY=your_openai_api_key_here

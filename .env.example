# Root Level Environment Configuration Template
# Copy this file to '.env' and fill in your local system parameters.
# NEVER commit the actual '.env' file containing secret keys or passwords to version control.

# Server Configuration
PORT=5000
FLASK_DEBUG=False
SECRET_KEY=your_secret_session_key_here

# Administrator Account Credentials
# These will be used to initialize/preserve the default administrator account
ADMIN_EMAIL=admin@giftai.com
ADMIN_PASSWORD=your_secure_admin_password_here

# Database Configuration (MySQL)
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=paper_plane_db

# External AI Service Credentials
# Generate your Groq API Key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: Gemini or OpenAI API Credentials
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Rate Limiting Configuration
# Limits are defined in Flask-Limiter format (e.g. "X per minute", "X per hour")
LIMIT_AI_GENERATION=10 per minute
LIMIT_AUTH=10 per 5 minutes
LIMIT_ADMIN=30 per minute
